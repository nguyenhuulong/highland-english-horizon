generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum LessonStatus {
  DRAFT
  PUBLISHED
}

enum LessonSource {
  MANUAL
  AI
  SAMPLE
  COMIC
}

model User {
  id                String                 @id @default(cuid())
  name              String
  email             String                 @unique
  password          String
  role              Role                   @default(STUDENT)
  ethnicGroup       String?
  ageGroup          Int?
  avatar            String                 @default("🧒")
  xp                Int                    @default(0)
  streak            Int                    @default(0)
  lastActiveAt      DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  aiLogs            AIGenerationLog[]
  aiTemplates       AITemplate[]
  lessonsAuthored   Lesson[]               @relation("LessonAuthor")
  progress          LessonProgress[]
  missionAttempts   MissionAttempt[]
  pronunciation     PronunciationAttempt[]
  badges            UserBadge[]
  comicCharacters   ComicCharacter[]  @relation("CharacterCreator")
  comicBackgrounds  ComicBackground[] @relation("BackgroundCreator")
  comicStories      ComicStory[]
}

model EthnicGroup {
  id           String            @id @default(cuid())
  slug         String            @unique
  nameVi       String
  nameEn       String
  emoji        String            @default("🌄")
  description  String            @db.Text
  costume      Json
  festivals    Json
  instruments  Json
  crafts       Json
  cuisine      Json
  locations    Json
  architecture String            @db.Text

  lessons      Lesson[]
  comicBackgrounds  ComicBackground[]
  comicCharacters   ComicCharacter[]
  comicStories ComicStory[]

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model Lesson {
  id              String                 @id @default(cuid())
  titleVi         String
  titleEn         String
  topic           String
  level           Int                    @default(1)
  ageGroup        Int                    @default(10)
  color           String                 @default("#E8643A")
  emoji           String                 @default("📖")
  descriptionVi   String
  vocabulary      Json
  panels          Json
  quiz            Json
  missions        Json                   @default("[]")
  status          LessonStatus           @default(DRAFT)
  source          LessonSource           @default(MANUAL)
  authorId        String
  author          User                   @relation("LessonAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  ethnicGroupId   String?
  ethnicGroup     EthnicGroup?           @relation(fields: [ethnicGroupId], references: [id])
  progress        LessonProgress[]
  pronunciation   PronunciationAttempt[]
  missionAttempts MissionAttempt[]
  aiLogs          AIGenerationLog[]

  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
}

model LessonProgress {
  id         String    @id @default(cuid())
  userId     String
  lessonId   String
  read       Boolean   @default(false)
  readAt     DateTime?
  quizScore  Int?
  quizTotal  Int?
  quizAt     DateTime?
  matchScore Int?
  pronScore  Int?
  xpEarned   Int       @default(0)

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson     Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  @@unique([userId, lessonId])
}

model PronunciationAttempt {
  id         String   @id @default(cuid())
  userId     String
  lessonId   String
  sentenceEn String
  transcript String
  score      Int
  createdAt  DateTime @default(now())

  lesson     Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MissionAttempt {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  missionId String
  correct   Boolean
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model Badge {
  id          String      @id @default(cuid())
  code        String      @unique
  icon        String
  name        String
  description String
  criteria    Json

  users       UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model AITemplate {
  id             String   @id @default(cuid())
  name           String
  description    String
  promptTemplate String   @db.Text
  createdById    String
  createdBy      User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
}

model AIGenerationLog {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String?
  input     Json
  status    String   @default("success")
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson?  @relation(fields: [lessonId], references: [id])
}

model ComicCharacter {
  id                String       @id @default(cuid())
  name              String
  nameEn            String
  role              String       @default("child")
  gender            String       @default("female")
  ethnicGroupId     String?
  ethnicGroup       EthnicGroup? @relation(fields: [ethnicGroupId], references: [id])
  descriptionVi     String       @db.Text
  descriptionEn     String       @db.Text
  costumePrompt     String       @db.Text
  appearancePrompt  String       @db.Text
  referenceImageUrl String?      @db.Text
  characterImageUrl String?      @db.Text
  thumbnailEmoji    String       @default("🧒")
  isActive          Boolean      @default(true)
  createdById       String
  createdBy         User         @relation("CharacterCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([ethnicGroupId])
}

model ComicBackground {
  id                String       @id @default(cuid())
  key               String       @unique
  nameVi            String
  nameEn            String
  category          String       @default("village")
  ethnicGroupId     String?
  ethnicGroup       EthnicGroup? @relation(fields: [ethnicGroupId], references: [id])
  prompt            String       @db.Text
  referenceImageUrl String?      @db.Text
  imageUrl          String?      @db.Text
  thumbnailEmoji    String       @default("🌄")
  isActive          Boolean      @default(true)
  createdById       String
  createdBy         User         @relation("BackgroundCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([key])
  @@index([category])
}

model ComicStory {
  id              String       @id @default(cuid())
  title           String
  titleEn         String
  topic           String
  templateKey     String       @default("INTRO_4")
  status          String       @default("draft") // draft | generating | ready | published
  ethnicGroupId   String?
  ethnicGroup     EthnicGroup? @relation(fields: [ethnicGroupId], references: [id], onDelete: SetNull)
  authorId        String
  author          User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  panels          Json         @default("[]")
  vocabulary      Json         @default("[]")
  quiz            Json         @default("[]")
  characterIds    Json         @default("[]")
  backgroundIds   Json         @default("[]")
  lessonId        String?      @unique

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([authorId])
  @@index([ethnicGroupId])
  @@index([status])
}
