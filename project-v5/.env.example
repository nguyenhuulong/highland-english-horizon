# PostgreSQL connection string (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/highland_english_horizon"

# NextAuth (Auth.js v5) — generate with: npx auth secret
AUTH_SECRET="replace-with-a-random-32-char-secret"

# ===== AI Lesson Generator =====
# Dùng bất kỳ provider tương thích "OpenAI Chat Completions API". Chọn 1 trong các cấu hình sau:

# --- Option 1: Groq (FREE, rất nhanh, khuyến nghị) — lấy key tại https://console.groq.com/keys
AI_BASE_URL="https://api.groq.com/openai/v1"
AI_MODEL="llama-3.3-70b-versatile"
AI_API_KEY="gsk_..."

# --- Option 2: Google Gemini (FREE tier) — lấy key tại https://aistudio.google.com/app/apikey
# AI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"
# AI_MODEL="gemini-2.0-flash"
# AI_API_KEY="AIza..."

# --- Option 3: OpenRouter (nhiều model free) — lấy key tại https://openrouter.ai/keys
# AI_BASE_URL="https://openrouter.ai/api/v1"
# AI_MODEL="meta-llama/llama-3.3-70b-instruct:free"
# AI_API_KEY="sk-or-..."

# --- Option 4: Ollama (chạy local, hoàn toàn miễn phí, không cần AI_API_KEY)
# Cài Ollama (https://ollama.com), chạy: ollama pull llama3.1
# AI_BASE_URL="http://localhost:11434/v1"
# AI_MODEL="llama3.1"
# AI_API_KEY=""

# --- Option 5: OpenAI (trả phí, rẻ với gpt-4o-mini)
# AI_BASE_URL="https://api.openai.com/v1"
# AI_MODEL="gpt-4o-mini"
# AI_API_KEY="sk-..."

# ===== AI Image Generation (Comic System) =====
# Provider: pollinations (miễn phí, không cần key) | together | replicate | openai
IMAGE_GEN_PROVIDER="pollinations"

# --- Together.ai (FLUX.1-schnell-Free, có free tier) --- lấy key tại https://api.together.ai
# IMAGE_GEN_PROVIDER="together"
# TOGETHER_API_KEY="..."

# --- Replicate (SDXL, trả phí theo request) --- lấy key tại https://replicate.com
# IMAGE_GEN_PROVIDER="replicate"
# REPLICATE_API_TOKEN="..."

# ===== Supabase Storage (cho upload ảnh trang phục/bối cảnh) =====
# Tạo bucket "comic-assets" trong Supabase Dashboard với policy: public read
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ===== Replicate (FLUX-dev, image conditioning cho panel) =====
# Lấy key tại https://replicate.com/account/api-tokens
# REPLICATE_API_TOKEN="r8_your_token_here"

# ===== Together.ai (FLUX.1-schnell-Free, gen character sheet & background) =====
# Lấy key tại https://api.together.ai
TOGETHER_API_KEY="your-together-api-key"
